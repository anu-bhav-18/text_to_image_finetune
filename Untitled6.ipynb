        "      latents = vae.encode(images).latent_dist.sample()\n",
        "      latents *= 0.18215\n",
        "      encoder_hidden_state = text_encoder.encode(text)[0]\n",
        "\n",
        "    noise = torch.rand_like(latents)\n",
        "    batch_size = latents.shape[0]\n",
        "    timestep = torch.randint(0,scheduler.config.num_train_timesteps,(batch_size,),device=DEVICE).long()\n",
        "\n",
        "    noisy_latents = scheduler.add_noise(latents,noise,timestep)\n",
        "\n",
        "    noise_pred = unet(noisy_latents,timestep,encoder_hidden_state)\n",
        "\n",
        "    loss = loss_fn(noise,noise_pred)\n",
        "\n",
