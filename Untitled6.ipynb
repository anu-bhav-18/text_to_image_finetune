      "source": [
        "def preprocessImage(item):\n",
        "  image = item['image'].convert(\"RGB\")\n",
        "  image = transform(image)\n",
        "  tokenized = tokenizer(\n",
        "        item[\"text\"],\n",
        "        max_length=77,\n",
        "        truncation=True,\n",
        "        padding=\"max_length\",\n",
        "        return_tensors=\"pt\"\n",
        "      )\n",
        "  return {\n",
        "      \"pixels_value\":image,\n",
        "      \"input_ids\":tokenized.input_ids[0]\n",
        "  }"
      ],
